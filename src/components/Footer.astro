---
const now = new Date();
const currentYear = now.getFullYear();
const lastUpdated = now.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
});
---

<footer class="sticky top-[100vh] py-4">
    <div class="max-w-[900px] mx-auto px-4">
        <div class="flex items-center justify-between font-mono text-xs text-primary-400">
            <span>&copy; {currentYear} Robert Balaban</span>
            <span>updated {lastUpdated}</span>
        </div>
    </div>
</footer>
