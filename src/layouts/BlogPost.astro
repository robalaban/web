---
import Layout from './Layout.astro';

interface Props {
    frontmatter: {
        title: string;
        publishDate: string;
        status?: "wip" | "finished" | "start";
    };
    rawContent: () => string;
}

const { frontmatter, rawContent } = Astro.props;

// Reading time
const words = rawContent().split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.ceil(words / 200));

---

<Layout title={frontmatter.title}>
    <article>
        <div class="mb-8">
            <a href="/" class="font-mono text-sm text-primary-600 hover:text-secondary-500 transition-colors tracking-wide">
                &larr;
            </a>
        </div>

        <header class="mb-12">
            <div class="flex items-center gap-3 mb-2">
                <h1 class="font-mono text-2xl tracking-wide text-primary-950">
                    {frontmatter.title}
                </h1>
                {frontmatter.status && frontmatter.status === "wip" && (
                    <span
                        class="inline-flex items-center px-2 py-1 text-xs font-mono bg-secondary-100 text-secondary-700 rounded border border-secondary-200"
                        title="This post is still being worked on, check back soon"
                    >
                        ( WIP )
                    </span>
                )}
            </div>
            <time class="font-mono text-sm text-primary-500 tracking-wide block">
                {frontmatter.publishDate}
            </time>
            <span class="font-mono text-sm text-primary-500 tracking-wide">
                {readingTime} min read
            </span>
        </header>

        <section class="prose">
            <slot />
        </section>
    </article>
</Layout>
